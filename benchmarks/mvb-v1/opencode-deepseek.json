{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "model": "deepseek-direct/deepseek-v4-flash",
  "small_model": "deepseek-direct/deepseek-v4-flash",
  "provider": {
    "deepseek-direct": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek direct API",
      "options": {
        "apiKey": "{env:DEEPSEEK_API_KEY}",
        "baseURL": "https://api.deepseek.com",
        "timeout": 300000
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (non-thinking)",
          "reasoning": false,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 8192,
            "output": 512
          },
          "options": {
            "thinking": {
              "type": "disabled"
            }
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro (non-thinking)",
          "reasoning": false,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 8192,
            "output": 512
          },
          "options": {
            "thinking": {
              "type": "disabled"
            }
          }
        },
        "deepseek-chat": {
          "name": "DeepSeek V4 Flash (non-thinking compatibility alias)",
          "reasoning": false,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 8192,
            "output": 512
          }
        }
      }
    }
  },
  "agent": {
    "build": {
      "temperature": 0,
      "permission": {
        "*": "deny",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "todowrite": "allow"
      }
    }
  }
}
